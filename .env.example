# ucdb — environment variables
#
# Copy to `.env` and fill in the values you need. The CLI does not auto-load
# `.env`; use a tool like `direnv`, `dotenv`, or `set -a; source .env; set +a`
# to export the variables into your shell before running `ucdb`.

# ---- Database --------------------------------------------------------------

# Default SQLite path. Overridden by the CLI's `--db` flag.
UCDB_DB=./ucdb.sqlite3

# ---- AI backend (required for `ucdb process` / `ucdb process-one`) --------

# API key for the AI provider. Required unless you only ever use `ucdb import`
# with pre-generated USLM XML.
OPENAI_API_KEY=sk-replace-me

# Endpoint for any OpenAI-compatible provider. Leave unset to use OpenAI.
# Examples:
#   OPENAI_BASE_URL=http://localhost:11434/v1          # Ollama
#   OPENAI_BASE_URL=http://localhost:8000/v1           # vLLM
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_BASE_URL=

# Model id used to convert extracted text into USLM XML. Override per-run with
# `--model`. Defaults to `gpt-5.4-mini` if unset.
UCDB_MODEL=gpt-5.4-mini

# ---- Optional --------------------------------------------------------------

# Path to a USLM XSD (e.g. USLM-2.x.xsd). When set, every imported XML is
# validated strictly against the schema in addition to the built-in
# well-formedness and structural checks.
# UCDB_USLM_XSD=./schemas/USLM-2.1.0.xsd

# When set to any non-empty value, `ucdb process` and `ucdb import` also dump
# a JSON summary of the run to stdout after the human-readable report.
# UCDB_JSON=1
